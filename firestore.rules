rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: investigations
    // Document ID: {investigationId}
    // Fields:
    //   - id: string (required)
    //   - ownerId: string (required)
    //   - collaborators: list (optional) - UIDs
    //   - collaboratorEmails: list (optional) - Emails
    //   - claim: string (optional)
    //   - data: map (optional)
    //   - chatMessages: list (optional)
    //   - requests: list (optional)
    //   - sources: list (optional)
    //   - researchPoints: list (optional)
    //   - suggestions: map (optional)
    //   - updatedAt: timestamp (required)
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - investigationIds: list (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user owns the resource (for user-owned documents)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if user is a collaborator on an investigation
    function isCollaborator(data) {
      return isAuthenticated() && 
        ((data.collaborators is list && request.auth.uid in data.collaborators) ||
         (data.collaboratorEmails is list && request.auth.token.email != null && request.auth.token.email in data.collaboratorEmails));
    }

    // Check if the user is an admin
    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "kaylayglass@gmail.com" && request.auth.token.email_verified == true)); // Default admin
    }

    // Validate that the document contains only the allowed fields
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Validate that the document contains the required fields
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // Domain Validator for Investigation
    function isValidInvestigation(data) {
      return hasRequiredFields(['id', 'ownerId', 'updatedAt']) &&
             data.id is string &&
             data.ownerId is string &&
             data.updatedAt is timestamp &&
             (!('collaborators' in data) || data.collaborators is list) &&
             (!('collaboratorEmails' in data) || data.collaboratorEmails is list) &&
             (!('chatMessages' in data) || data.chatMessages is list && data.chatMessages.size() < 1000) &&
             (!('requests' in data) || data.requests is list && data.requests.size() < 500) &&
             (!('sources' in data) || data.sources is list && data.sources.size() < 500) &&
             (!('researchPoints' in data) || data.researchPoints is list && data.researchPoints.size() < 1000);
    }

    // Domain Validator for UserProfile
    function isValidUserProfile(data) {
      return hasRequiredFields(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('investigationIds' in data) || data.investigationIds is list);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Investigations collection
    match /investigations/{investigationId} {
      allow read: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || 
        (resource.data.collaborators is list && request.auth.uid in resource.data.collaborators) ||
        (resource.data.collaboratorEmails is list && request.auth.token.email != null && request.auth.token.email in resource.data.collaboratorEmails) ||
        isAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid && isValidInvestigation(request.resource.data);
      allow update: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || 
        (resource.data.collaborators is list && request.auth.uid in resource.data.collaborators) ||
        (resource.data.collaboratorEmails is list && request.auth.token.email != null && request.auth.token.email in resource.data.collaboratorEmails) ||
        isAdmin()
      ) && isValidInvestigation(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUserProfile(request.resource.data);
    }

    // Test collection for connection check
    match /test/connection {
      allow read: if true;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
